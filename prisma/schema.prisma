generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("donor")
  phone     String?
  address   String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations      FoodDonation[]
  pickupRequests  PickupRequest[]  @relation("NgoRequests")
  deliveries      PickupRequest[]  @relation("VolunteerDeliveries")
  products        FarmerProduct[]
}

model FoodDonation {
  id          String   @id @default(cuid())
  donorId     String
  donorName   String
  foodName    String
  description String
  quantity    String
  unit        String
  expiryTime  DateTime
  category    String
  imageUrl    String?
  address     String
  lat         Float?
  lng         Float?
  status      String   @default("available")
  claimedBy   String?
  volunteerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donor   User              @relation(fields: [donorId], references: [id])
  requests PickupRequest[]
}

model PickupRequest {
  id            String   @id @default(cuid())
  donationId    String
  ngoId         String
  ngoName       String
  volunteerId   String?
  volunteerName String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  donation FoodDonation @relation(fields: [donationId], references: [id])
  ngo      User         @relation("NgoRequests", fields: [ngoId], references: [id])
  volunteer User?       @relation("VolunteerDeliveries", fields: [volunteerId], references: [id])
}

model FarmerProduct {
  id          String   @id @default(cuid())
  farmerId    String
  farmerName  String
  productName String
  description String
  price       Float
  unit        String
  quantity    Int
  category    String
  imageUrl    String?
  address     String
  lat         Float?
  lng         Float?
  isOrganic   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmer User @relation(fields: [farmerId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
